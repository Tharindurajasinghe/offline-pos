# Admin credentials (hardcoded - do not share)
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin123

# Token secret key
VITE_TOKEN_SECRET=myScrecteKey

# Trial period (days)
VITE_TRIAL_DAYS=5

# Default low stock threshold
VITE_LOW_STOCK_THRESHOLD=5

# Expiry warning (days before expiry to show warning)
VITE_EXPIRY_WARNING_DAYS=30

# Currency symbol
VITE_CURRENCY=Rs.

# App version
VITE_APP_VERSION=1.0.0